# ── Harness Evolution Workshop — local lab routing ────────────────────────────
# Copy to `workshop/.env` (or repo-root `.env`) and adjust. All inference is local.
#
# IMPORTANT: llama.cpp's server (used by BOTH Ollama and standalone llama-server)
# treats the LLAMA_API_KEY env var as a REQUIRED server key. If you have it set
# (e.g. a Meta Llama key), every local call 401s with "Invalid API Key". Fix:
#   unset LLAMA_API_KEY     # before starting the server
# ------------------------------------------------------------------------------

# Inner task agent (frozen). Paper's retail experiment used a ~27B model; qwen3:32b
# is the faithful local analog. Use qwen3:8b for faster iteration / bigger inverse-
# scaling lift demos.
TAU2_AGENT_MODEL=openai/qwen3:32b
TAU2_AGENT_API_BASE=http://127.0.0.1:11434/v1

# User simulator — smaller/faster local model.
TAU2_USER_MODEL=openai/qwen3:8b
OPENAI_API_BASE=http://127.0.0.1:11434/v1
OPENAI_API_KEY=sk-local          # any non-empty value; local server ignores it

# Meta-agent = Claude Code (you, driving the loop). No API model needed here.
# To use the built-in MetaAgent instead: TAU2_META_MODEL=anthropic/... + ANTHROPIC_API_KEY

# ── Standalone llama-server fallback (if Ollama is unavailable) ────────────────
# Serve blobs on distinct ports and point the *_API_BASE vars above at them:
#   AGENT  -> http://127.0.0.1:8088/v1   (qwen3:32b)
#   USER   -> http://127.0.0.1:8089/v1   (qwen3:8b)
