# =============================================================
# Agentic Engineering Stack Workshops — environment reference
# Copy to .env (local) or .dev.vars (wrangler). Never commit real keys.
# =============================================================

# --- Models / routing (Stations 01-05, 08) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...            # optional, router fallback comparison
OPENROUTER_API_KEY=sk-or-...     # optional, multi-model routing

# --- Second brain / memory (Station 03) ---
MEM0_API_KEY=                    # or run local; see mem0 setup

# --- Telemetry / receipts (Station 07) ---
OTEL_EXPORTER_OTLP_ENDPOINT=     # optional; defaults to console exporter

# --- Deployment (Station 09) ---
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Conversion tracking (landing/ only) ---
GTM_CONTAINER_ID=GTM-XXXXXXX
META_PIXEL_ID=
TIKTOK_PIXEL_ID=
GA4_MEASUREMENT_ID=G-XXXXXXX

# --- GitHub (push to Organized-AI) ---
GITHUB_TOKEN=ghp_...
